{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "KeyVaultName": "",
  "ConnectionStrings": {
    "DefaultConnection": "Server={DbServer};Port={DbPort};Database={DbName};Uid={DbUser};Pwd={DbPassword};"
  },
  "Kafka": {
    "BootstrapServers": "127.0.0.1:9092",
    "TopicIrDedoDuro": "fiscal.ir.dedoduro",
    "TopicIrVenda": "fiscal.ir.venda",
    "TopicCompraExecutada": "operacoes.compra.executada"
  },
  "Cotacao": {
      "DiretorioArquivos": "C:\\B3"
  },
  "AzureStorageBlob": {
      "Endpoint": "https://{StorageAccountName}.blob.core.windows.net",
      "ContainerName": "cotahist"
  }
}